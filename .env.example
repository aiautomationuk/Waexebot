# Copy this file to .env and fill in your values
# On Render, set these in the dashboard under Environment Variables

# Your OpenAI API key (from platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# Your OpenAI Assistant ID (from platform.openai.com/assistants)
ASSISTANT_ID=asst_...

# Set to true to also reply in WhatsApp groups (default: false)
REPLY_IN_GROUPS=false

# --- Render sets this automatically, do not change ---
# PORT=3000

# --- Set automatically by render.yaml, do not change ---
# DATA_DIR=/data
